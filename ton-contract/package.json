{
  "name": "nft-badge-board-contract",
  "version": "1.0.0",
  "private": true,
  "description": "TON Blueprint + Tact (BadgeBoard). Run npm install here, not from repo root.",
  "scripts": {
    "build": "blueprint build --all",
    "deploy:testnet": "blueprint run deployBadgeBoard --testnet --tonconnect",
    "run:setCode": "blueprint run setCodeBadge --testnet --tonconnect",
    "run:claim": "blueprint run claimByCode --testnet --tonconnect",
    "run:getBadges": "blueprint run getBadges --testnet --tonconnect",
    "run:getStudents": "blueprint run getStudents --testnet --tonconnect"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "devDependencies": {
    "@tact-lang/compiler": "^1.6.13",
    "@ton/blueprint": "^0.44.2",
    "@ton/core": "^0.63.1",
    "@ton/ton": "^16.2.4",
    "typescript": "^5.6.3"
  }
}
